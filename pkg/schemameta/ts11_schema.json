{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.siros.org/ts11-schema-meta.json",
  "title": "TS11 SchemaMeta",
  "description": "Schema for TS11 Catalogue of Attestations SchemaMeta objects",
  "type": "object",
  "required": ["id", "version", "attestationLoS", "bindingType", "supportedFormats", "schemaURIs"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier (UUID) for the attestation schema"
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Version of the schema"
    },
    "attestationLoS": {
      "type": "string",
      "description": "Level of Security for the attestation"
    },
    "bindingType": {
      "type": "string",
      "description": "Type of credential binding (e.g. key, biometric)"
    },
    "supportedFormats": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "List of supported credential format identifiers"
    },
    "schemaURIs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["formatIdentifier", "uri"],
        "properties": {
          "formatIdentifier": {
            "type": "string"
          },
          "uri": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "description": "URIs for format-specific schema files"
    },
    "rulebookURI": {
      "type": "string",
      "format": "uri",
      "description": "URI of the attestation rulebook"
    },
    "trustedAuthorities": {
      "type": "array",
      "description": "List of trusted authorities for this attestation type"
    }
  },
  "additionalProperties": false
}
